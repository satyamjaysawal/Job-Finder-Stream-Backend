# ── python-dotenv (copy to `.env` and fill in secrets) ──────────────────────
# load_dotenv() finds this file automatically from the process working directory.

# MongoDB (required)
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=job_portal

# Optional collection names (defaults shown)
# JOBS_COLLECTION_NAME=jobs
# CONFIG_COLLECTION_NAME=config
# SCRAPE_JSONS_COLLECTION_NAME=scrape_jsons

# Server
HOST=127.0.0.1
PORT=5000
BASE_URL=http://127.0.0.1:5000
API_PREFIX=/api
RELOAD=true

# Frontend origin (used as default CORS + docs)
FRONTEND_URL=http://127.0.0.1:5173

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With
